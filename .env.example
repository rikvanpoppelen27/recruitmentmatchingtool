# ---------------------------------------------------------------------------
# Database (Supabase Postgres, of lokale Docker Postgres — zie docker-compose.yml)
# DIRECT_URL is nodig voor `prisma migrate` als DATABASE_URL via een connection
# pooler (Supabase pgbouncer) loopt. Lokaal met Docker zijn beide gelijk.
#
# Let op bij Supabase: de directe host "db.<project-ref>.supabase.co" is
# IPv6-only. Geen IPv6 op je machine/netwerk? Gebruik dan de Supavisor-pooler
# (Dashboard → Project Settings → Database → Connection string):
#   DATABASE_URL="postgresql://postgres.<project-ref>:<wachtwoord>@aws-0-<regio>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_URL="postgresql://postgres.<project-ref>:<wachtwoord>@aws-0-<regio>.pooler.supabase.com:5432/postgres"
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recruitmenttool"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/recruitmenttool"

# ---------------------------------------------------------------------------
# Supabase (Storage voor CV's en gegenereerde PDF's; later ook Auth in fase 7)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET_CVS="cvs"
SUPABASE_STORAGE_BUCKET_PRESENTATIONS="presentations"

# ---------------------------------------------------------------------------
# Anthropic (alle AI-calls via lib/ai/)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ---------------------------------------------------------------------------
# Adzuna (vacature-import, fase 1)
# Zoekterm-varianten, regio's en paginering staan in src/config/import.ts,
# niet hier — dit zijn alleen de credentials.
# ---------------------------------------------------------------------------
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# ---------------------------------------------------------------------------
# Matching (fase 3)
# ---------------------------------------------------------------------------
MATCH_THRESHOLD="90"

NODE_ENV="development"
